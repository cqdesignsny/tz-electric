{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/dispatch-escalation",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/claire-daily-analysis",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/hcp-customer-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/end-of-day-flags",
      "schedule": "0 22,23 * * *"
    }
  ]
}
